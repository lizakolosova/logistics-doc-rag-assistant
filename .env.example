# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=documents        # ChromaDB collection name; change per environment or tenant

# --- PostgreSQL ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_URL=postgresql+asyncpg://legal:legal@localhost:5432/legal_rag

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K=10
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# --- Document limits ---
MAX_FILE_SIZE_MB=50
MAX_PAGES=200

# --- Generation ---
PROMPT_CHUNK_MAX_CHARS=1500        # Max chars per retrieved chunk sent to the LLM prompt

# --- Evaluation ---
EVAL_DATA_PATH=/app/eval_data/legal_qa_golden.json  # Override with a local path when running outside Docker
